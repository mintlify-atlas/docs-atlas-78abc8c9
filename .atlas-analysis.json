  "keyFeatures": [
    "JWT-based authentication with access and refresh tokens",
    "Complete transaction management (income and expenses)",
    "Custom category system with color and icon support",
    "Automatic balance calculation and financial tracking",
    "Date range filtering for transactions",
    "Argon2 password hashing for security"
  ],
  "publicApiSurface": [
    "POST /register - Register a new user",
    "POST /login - Login and receive JWT tokens",
    "POST /refresh - Refresh access token",
    "GET /me - Get current user information",
    "PATCH /change-password - Change user password",
    "PATCH /update-profile - Update user profile",
    "GET /transactions - List all transactions with optional date filtering",
    "GET /transactions/recent - Get recent transactions (last 3 days)",
    "GET /transactions/{id} - Get a specific transaction",
    "POST /transactions - Create a new transaction",
    "PUT /transactions/{id} - Update a transaction",
    "DELETE /transactions/{id} - Delete a transaction",
    "DELETE /transactions - Delete all transactions",
    "GET /categories - List all categories",
    "GET /category/{id} - Get a specific category",
    "GET /category/{id}/transactions - Get all transactions in a category",
    "POST /categories - Create a new category",
    "DELETE /category/{id} - Delete a category"
  ]
}
